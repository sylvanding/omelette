# =============================================================================
# Omelette Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_ENV=development
# Set to true for development only. Production MUST use false.
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
# SECURITY: Change this to a random secret key in production!
APP_SECRET_KEY=change-me-to-a-random-secret-key

# --- API Authentication ---
# Set to enable API key protection. Leave empty to disable (suitable for local dev).
API_SECRET_KEY=

# --- Database ---
DATABASE_URL=sqlite:///./data/omelette.db

# --- Data Storage ---
# Where PDFs, OCR output, and other data files are stored
DATA_DIR=./data
PDF_DIR=${DATA_DIR}/pdfs
OCR_OUTPUT_DIR=${DATA_DIR}/ocr_output
CHROMA_DB_DIR=${DATA_DIR}/chroma_db

# --- LLM: Default Provider ---
# Options: aliyun, volcengine, openai, anthropic, ollama, mock
LLM_PROVIDER=mock
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# --- LLM: Aliyun Bailian ---
# OpenAI-compatible endpoint (general: dashscope.aliyuncs.com, coding: coding.dashscope.aliyuncs.com)
ALIYUN_API_KEY=sk-sp-xxxxx
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL=qwen3.5-plus

# --- LLM: Volcengine (Doubao) ---
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-seed-1-6-flash-250828

# --- LLM: OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- LLM: Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- LLM: Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Embedding ---
# Provider: local (HuggingFace) | api (OpenAI) | mock
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_API_KEY=
RERANKER_MODEL=tomaarsen/Qwen3-Reranker-8B-seq-cls

# --- OCR ---
# PaddleOCR language: ch (Chinese+English) | en (English only)
OCR_LANG=ch

# --- PDF Parsing ---
# Parser selection: auto (pdfplumber first, fallback to MinerU) | mineru | pdfplumber
PDF_PARSER=mineru
# MinerU independent API service URL
MINERU_API_URL=http://localhost:8010
# MinerU backend: pipeline | hybrid-auto-engine | vlm-auto-engine
MINERU_BACKEND=pipeline
# Timeout per PDF in seconds
MINERU_TIMEOUT=8000

# --- GPU ---
# Comma-separated GPU IDs for OCR/embedding tasks
CUDA_VISIBLE_DEVICES=5,6,7

# --- Network Proxy ---
# HTTP_PROXY=http://your-proxy:port
# HTTPS_PROXY=http://your-proxy:port

# --- HuggingFace Mirror ---
# For users in China, set to https://hf-mirror.com to speed up model downloads
HF_ENDPOINT=

# --- External APIs ---
# Semantic Scholar (optional, increases rate limit)
SEMANTIC_SCHOLAR_API_KEY=
# Unpaywall (requires email)
UNPAYWALL_EMAIL=your-email@example.com

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://0.0.0.0:3000
