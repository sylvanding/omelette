# =============================================================================
# Omelette Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-secret-key

# --- Database ---
DATABASE_URL=sqlite:///./data/omelette.db

# --- Data Storage ---
# Where PDFs, OCR output, and other data files are stored
DATA_DIR=/data0/djx/omelette
PDF_DIR=${DATA_DIR}/pdfs
OCR_OUTPUT_DIR=${DATA_DIR}/ocr_output
CHROMA_DB_DIR=${DATA_DIR}/chroma_db

# --- LLM: Aliyun Bailian (Coding Plan) ---
# OpenAI-compatible endpoint
ALIYUN_API_KEY=sk-sp-xxxxx
ALIYUN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
ALIYUN_MODEL=qwen3.5-plus

# --- LLM: Volcengine (Doubao) ---
# OpenAI-compatible endpoint
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-seed-1-6-flash-250828

# --- Default LLM Provider ---
# Options: aliyun, volcengine, mock
LLM_PROVIDER=mock

# --- Embedding Model ---
# Local model name (downloaded from HuggingFace)
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- GPU ---
# Comma-separated GPU IDs for OCR/embedding tasks
CUDA_VISIBLE_DEVICES=0,3

# --- Network Proxy ---
HTTP_PROXY=http://127.0.0.1:20171/
HTTPS_PROXY=http://127.0.0.1:20171/

# --- HuggingFace Mirror ---
# For users in China, set to https://hf-mirror.com to speed up model downloads
HF_ENDPOINT=

# --- External APIs ---
# Semantic Scholar (optional, increases rate limit)
SEMANTIC_SCHOLAR_API_KEY=
# Unpaywall (requires email)
UNPAYWALL_EMAIL=your-email@example.com

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://0.0.0.0:3000
