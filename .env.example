# Omelette Configuration
# Copy to .env and fill in values.

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-secret-key

# Database (SQLite by default)
# DATABASE_URL=sqlite:///./data/omelette.db

# Data Storage (defaults to ./data subdirectories)
# DATA_DIR=./data

# LLM Provider: mock | openai | anthropic | aliyun | volcengine | ollama
LLM_PROVIDER=mock

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Aliyun Bailian (DashScope)
# ALIYUN_API_KEY=...
# ALIYUN_MODEL=qwen3.5-plus

# Volcengine
# VOLCENGINE_API_KEY=...
# VOLCENGINE_MODEL=doubao-seed-1-6-flash-250828

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Embedding: local | api | mock
EMBEDDING_PROVIDER=mock

# GPU Mode: conservative | balanced | aggressive
GPU_MODE=conservative

# HuggingFace Mirror (for China users)
# HF_ENDPOINT=https://hf-mirror.com

# External APIs
# SEMANTIC_SCHOLAR_API_KEY=
# UNPAYWALL_EMAIL=your@email.com
